{
  "name": "senior-hcm-connector",
  "version": "0.1.0",
  "private": true,
  "description": "Conector backend para WebServices SOAP Senior HCM XT/Rubi, preparado para uso seguro por LLM/Codex.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
